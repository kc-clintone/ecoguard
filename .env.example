# EcoGuard Environment Configuration

# Server port (default: 8080)
PORT=8080

# Database path (default: ecoguard.db in current directory)
# For production, use an absolute path or a persistent volume
DB_PATH=/var/lib/ecoguard/ecoguard.db

# API Keys (required for full functionality)
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Plant.id API Key (optional, for enhanced crop detection)
# Get from: https://plant.id/api
PLANT_ID_API_KEY=your_plant_id_api_key_here
